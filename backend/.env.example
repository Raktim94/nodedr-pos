# Copy to .env for local (non-Docker) development.
# Inside Docker Compose these are set directly in docker-compose.yml.

# Relative to wherever you run `node`/`npm run dev` from — i.e. the
# backend/ directory per the README's local-dev instructions, so this
# resolves to backend/data/pos.db.
DATABASE_URL="file:./data/pos.db"
PORT=4000
FRONTEND_ORIGIN="http://localhost:1994"

# Optional: pin a JWT signing secret. If unset, one is auto-generated on
# first boot and persisted to data/.jwt-secret so sessions survive restarts.
# JWT_SECRET=

# Set to "true" only if the app is served over HTTPS.
COOKIE_SECURE=false
